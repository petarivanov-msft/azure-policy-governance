{
  "properties": {
    "displayName": "Restrict allowed VM SKUs",
    "description": "Only allows virtual machines from an approved list of SKUs. Keeps costs predictable and blocks oversized VMs.",
    "policyType": "Custom",
    "mode": "Indexed",
    "parameters": {
      "allowedSkus": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed VM SKUs",
          "description": "List of permitted VM SKU names"
        },
        "defaultValue": [
          "Standard_B2s",
          "Standard_B2ms",
          "Standard_D2s_v5",
          "Standard_D4s_v5",
          "Standard_D2as_v5",
          "Standard_D4as_v5"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "not": {
              "field": "Microsoft.Compute/virtualMachines/sku.name",
              "in": "[parameters('allowedSkus')]"
            }
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
