{
  "properties": {
    "displayName": "Require managed disks for VMs",
    "description": "Denies virtual machines that use unmanaged disks (storage account-based VHDs). Everyone should be on managed disks by now.",
    "policyType": "Custom",
    "mode": "Indexed",
    "parameters": {},
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "anyOf": [
              {
                "field": "Microsoft.Compute/virtualMachines/osDisk.vhd.uri",
                "exists": "true"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.vhd",
                "exists": "true"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
